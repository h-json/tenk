# 이 파일을 .env 로 복사한 뒤 값을 채우고 docker compose 를 실행한다.
#   cp .env.example .env  &&  편집
# .env 는 비밀번호가 들어가므로 절대 git 에 커밋하지 말 것 (.gitignore 에 등록됨).

# 백엔드가 DB 에 접속할 때 쓰는 tenk 계정 비밀번호. (MariaDB 사용자 tenk 의 비번 = 백엔드 datasource 비번, 같은 값)
DB_PASSWORD=change-me-strong-db-password

# MariaDB root 비밀번호. tenk 계정과 다른 값으로.
DB_ROOT_PASSWORD=change-me-different-root-password
